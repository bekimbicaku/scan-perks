{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "sync-version": "node scripts/sync-version.js",
    "build:web": "node scripts/sync-version.js && expo export --platform web",
    "build:web:github": "node scripts/sync-version.js && cross-env EXPO_EXPORT_STATIC=1 expo export --platform web && node scripts/prepare-github-pages.js",
    "serve:web": "npx expo serve dist",
    "build:android": "cross-env EAS_NO_VCS=1 eas build --platform android --profile production",
    "build:android:preview": "cross-env EAS_NO_VCS=1 eas build --platform android --profile preview",
    "submit:android": "eas submit --platform android --profile production",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^14.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~53.0.27",
    "expo-asset": "~11.1.7",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.11",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-modules-core": "~2.5.0",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "~14.2.0",
    "firebase": "^10.14.1",
    "lucide-react-native": "^0.475.0",
    "qrcode": "^1.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "stripe": "^18.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/server": "^0.6.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "~19.0.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^7.0.3",
    "react-native-svg-transformer": "^1.5.0",
    "typescript": "~5.8.3"
  }
}
