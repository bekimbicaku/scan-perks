{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "sync-version": "node scripts/sync-version.js",
    "build:web": "node scripts/sync-version.js && expo export --platform web",
    "build:web:github": "node scripts/sync-version.js && cross-env EXPO_EXPORT_STATIC=1 expo export --platform web && node scripts/prepare-github-pages.js",
    "build:web:vercel": "node scripts/sync-version.js && cross-env EXPO_EXPORT_STATIC=1 expo export --platform web && node scripts/prepare-github-pages.js",
    "serve:web": "npx expo serve dist",
    "build:android": "powershell -ExecutionPolicy Bypass -File ./scripts/eas-build-android.ps1 production",
    "build:android:preview": "powershell -ExecutionPolicy Bypass -File ./scripts/eas-build-android.ps1 preview",
    "submit:android": "cross-env EAS_NO_VCS=1 TEMP=C:\\Temp\\eas TMP=C:\\Temp\\eas eas submit --platform android --profile production",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^15.0.3",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^10.14.1",
    "lucide-react-native": "^0.475.0",
    "qrcode": "^1.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "stripe": "^18.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/server": "^0.6.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^7.0.3",
    "react-native-svg-transformer": "^1.5.0",
    "typescript": "~5.9.2"
  }
}
