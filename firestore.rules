rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isBusinessOwner(businessId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/businesses/$(businessId)) &&
        get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    function isValidScanIncrement() {
      let data = request.resource.data;
      return data.keys().hasAll(['businessId', 'lastScan', 'totalScans']) &&
             data.businessId is string &&
             data.lastScan is timestamp &&
             data.totalScans is number &&
             data.totalScans > 0;
    }

    function isValidStatsIncrement() {
      let data = request.resource.data;
      return (!('totalScans' in data) || data.totalScans is number) &&
             (!('uniqueCustomers' in data) || data.uniqueCustomers is number);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && isOwner(userId);

      match /scans/{businessId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId) && isValidScanIncrement();
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      match /rewards/{rewardId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() &&
                     isOwner(userId) &&
                     request.resource.data.keys().hasAll(['businessId', 'createdAt', 'redeemed']) &&
                     request.resource.data.redeemed == false;
        allow update: if isAuthenticated() && (
          (isOwner(userId) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['redeemed', 'redeemedAt'])) ||
          (isBusinessOwner(resource.data.businessId) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['redeemed', 'redeemedAt', 'redeemedBy']) &&
           request.resource.data.redeemed == true)
        );
      }
    }

    match /businesses/{businessId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                   request.resource.data.keys().hasAll(['name', 'type', 'email', 'ownerId']) &&
                   request.resource.data.ownerId == request.auth.uid;
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);

      match /qr_codes/{qrId} {
        allow read: if true;
        allow write: if isBusinessOwner(businessId);
        allow update: if isAuthenticated() &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedAt', 'usedBy']);
      }

      match /statistics/{docId} {
        allow read: if true;
        allow create, update: if isAuthenticated() && isValidStatsIncrement();
        allow delete: if isBusinessOwner(businessId);
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if isBusinessOwner(businessId);
      }

      match /loyalty/{docId} {
        allow read: if true;
        allow write: if isBusinessOwner(businessId) &&
                    request.resource.data.keys().hasAll(['scansRequired', 'reward']);
      }

      match /rewards/{rewardId} {
        allow read: if isAuthenticated();
        allow write: if isBusinessOwner(businessId);
      }

      match /offers/{offerId} {
        allow read: if isAuthenticated();
        allow write: if isBusinessOwner(businessId);
      }

      match /analytics/{docId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated();
        allow delete: if isBusinessOwner(businessId);
      }

      match /customers/{customerId} {
        allow read: if isBusinessOwner(businessId);
        allow create, update: if isAuthenticated() && request.auth.uid == customerId;
      }

      match /pulse/{docId} {
        allow read: if isBusinessOwner(businessId);
        allow create, update: if isAuthenticated();
      }

      match /pulse_logs/{logId} {
        allow create: if isAuthenticated();
        allow read: if isBusinessOwner(businessId);
      }
    }

    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
